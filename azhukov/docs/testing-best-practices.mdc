## Page Object Model (POM)

Для страниц с множеством взаимодействий — выноси локаторы и действия в классы:

```typescript
// pages/VacancyCreatePage.ts
import { type Page, type Locator } from '@playwright/test';

export class VacancyCreatePage {
  readonly page: Page;
  readonly titleInput: Locator;
  readonly descriptionEditor: Locator;
  readonly companyEditor: Locator;
  readonly salaryToInput: Locator;
  readonly createButton: Locator;
  readonly cancelButton: Locator;

  constructor(page: Page) {
    this.page = page;
    this.titleInput = page.getByRole('textbox', { name: 'Frontend Разработчик' });
    this.descriptionEditor = page.locator('.ql-editor').first();
    this.companyEditor = page.locator('.ql-editor').nth(1);
    this.salaryToInput = page.getByRole('textbox', { name: 'до *' });
    this.createButton = page.getByRole('button', { name: 'Создать вакансию' });
    this.cancelButton = page.getByRole('button', { name: 'Отмена' });
  }

  async goto() {
    await this.page.goto('/recruiter/');
    await this.page.getByRole('button', { name: 'Новая вакансия' }).click();
    await this.page.waitForURL(/\/recruiter\/vacancy\/create/);
  }

  async fillMinimal(title: string) {
    await this.titleInput.fill(title);
    await this.descriptionEditor.click();
    await this.descriptionEditor.fill('Описание вакансии');
    await this.companyEditor.click();
    await this.companyEditor.fill('О компании');
    await this.salaryToInput.fill('200000');
  }

  async submit() {
    await this.createButton.click();
  }
}
```

Использование в тесте:

```typescript
import { VacancyCreatePage } from '../../../pages/VacancyCreatePage';

test('Создание вакансии', async ({ page }) => {
  const vacancyPage = new VacancyCreatePage(page);
  await vacancyPage.goto();
  await vacancyPage.fillMinimal('Тестовая вакансия');
  await vacancyPage.submit();
  await expect(page).toHaveURL(/\/recruiter\/vacancy\/\d+/);
});
```

