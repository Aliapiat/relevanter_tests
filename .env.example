# Copy to .env and fill in real values. NEVER commit the real .env.

# ── Учётки ──────────────────────────────────────────────────────
# Админ. Используется ТОЛЬКО в tests/test_login.py — там проверяем
# позитив/негатив входа, регистр, пробелы, XSS и т.п. В остальных
# тестах под админом НЕ логинимся (см. обоснование в conftest.py).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Обычный рекрутёр. Основной юзер для всех не-login тестов.
# Есть на всех стендах (dev/staging/preprod/prod).
# На текущем тестовом аккаунте логин и пароль совпадают.
RECRUITER_EMAIL=
RECRUITER_PASSWORD=

# ── Playwright ──────────────────────────────────────────────────
HEADLESS=false
BROWSER=chromium
SLOW_MO=0
DEFAULT_TIMEOUT=30000
